SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Must also be listed in Supabase → Authentication → URL Configuration → Redirect URLs
# Examples:
#   curamind://auth-callback
#   http://localhost:3000/auth-callback   (web)
SUPABASE_AUTH_REDIRECT=curamind://auth-callback

# Backend API (Express). Omit to use platform defaults:
#   Android emulator → http://10.0.2.2:3000
#   iOS Simulator / Windows / macOS / Linux / Chrome → http://localhost:3000
# Physical phone on same Wi‑Fi → use your PC LAN IP, e.g.:
# API_BASE_URL=http://192.168.1.20:3000
# API_BASE_URL=http://localhost:3000
