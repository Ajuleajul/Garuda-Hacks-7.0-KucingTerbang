

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  PSYCHIATRIST
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  full_name  String
  role       Role
  created_at DateTime @default(now())

  mood_logs                     MoodLog[]
  patient_links                 PatientPsychiatristLink[] @relation("PatientLinks")
  psychiatrist_links            PatientPsychiatristLink[] @relation("PsychiatristLinks")
  patient_notes                 SessionNote[]             @relation("PatientSessionNotes")
  psychiatrist_notes            SessionNote[]             @relation("PsychiatristSessionNotes")
}

model JoinGroup {
  id                  String    @id @default(uuid())
  psychiatrist_id     String
  psychiatrist_name   String?
  psychiatrist_email  String?
  code                String    @unique
  name                String
  is_active           Boolean   @default(true)
  expires_at          DateTime?
  created_at          DateTime  @default(now())

  care_links          CareLink[]

  @@index([psychiatrist_id])
}

model CareLink {
  id               String     @id @default(uuid())
  patient_id       String     @unique
  patient_name     String?
  psychiatrist_id  String
  join_group_id    String?
  status           LinkStatus @default(ACTIVE)
  monitoring_on    Boolean    @default(true)
  created_at       DateTime   @default(now())

  join_group       JoinGroup? @relation(fields: [join_group_id], references: [id], onDelete: SetNull)

  @@index([psychiatrist_id])
}

model MoodLog {
  id             String   @id @default(uuid())
  patient_id     String
  patient        User     @relation(fields: [patient_id], references: [id])
  mood_score     Int
  triggers       String[]
  urge_intensity Int
  coping_journal String?
  created_at     DateTime @default(now())
}

enum DiaryEntryKind {
  DBT_CARD
  COPING
}

model DiaryEntry {
  id               String         @id @default(uuid())
  patient_id       String
  kind             DiaryEntryKind
  mood             Int?
  affect_intensity Int?
  urge_nssi        Int?
  urge_substance   Int?
  emotions         String[]
  triggers         String[]
  skills           String[]
  notes            String?
  situation        String?
  thoughts         String?
  behavior         String?
  outcome          String?
  created_at       DateTime       @default(now())

  @@index([patient_id, created_at])
}

enum LinkStatus {
  PENDING
  ACTIVE
}

enum LogStatus {
  TAKEN
  MISSED
}

model PatientPsychiatristLink {
  id              String     @id @default(uuid())
  patient_id      String
  psychiatrist_id String
  status          LinkStatus @default(PENDING)
  created_at      DateTime   @default(now())

  patient         User       @relation("PatientLinks", fields: [patient_id], references: [id])
  psychiatrist    User       @relation("PsychiatristLinks", fields: [psychiatrist_id], references: [id])
}

model Medication {
  id               String   @id @default(uuid())
  patient_id       String
  patient_name     String?
  psychiatrist_id  String
  name             String
  dosage_and_freq  String
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  logs             MedicationLog[]

  @@index([patient_id])
  @@index([psychiatrist_id])
}

model MedicationLog {
  id             String    @id @default(uuid())
  medication_id  String
  patient_id     String
  status         LogStatus
  day_key        String
  logged_at      DateTime  @default(now())

  medication     Medication @relation(fields: [medication_id], references: [id])

  @@unique([medication_id, day_key])
  @@index([patient_id, logged_at])
}

model SessionNote {
  id              String     @id @default(uuid())
  patient_id      String
  psychiatrist_id String
  clinical_notes  String
  created_at      DateTime   @default(now())

  patient         User       @relation("PatientSessionNotes", fields: [patient_id], references: [id])
  psychiatrist    User       @relation("PsychiatristSessionNotes", fields: [psychiatrist_id], references: [id])
}